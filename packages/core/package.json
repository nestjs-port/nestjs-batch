{
  "name": "@nestjs-batch/core",
  "version": "0.0.0",
  "private": false,
  "description": "Core batch abstractions and orchestration primitives for NestJS Batch",
  "keywords": [
    "batch",
    "core",
    "nestjs"
  ],
  "homepage": "https://nestjs-port.github.io/nestjs-batch",
  "bugs": {
    "url": "https://github.com/nestjs-port/nestjs-batch/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-batch",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "prepack": "shx cp ../../README.md README.md"
  },
  "devDependencies": {
    "@nestjs-batch/infrastructure": "workspace:*",
    "@nestjs-port/core": "^0.1.1"
  },
  "peerDependencies": {
    "@nestjs-batch/infrastructure": "workspace:*",
    "@nestjs-port/core": "^0.1.1"
  }
}
