{
  "name": "@nestjs-batch/core",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@nestjs-batch/commons": "workspace:*",
    "@nestjs-batch/infrastructure": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs-batch/commons": "*"
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  }
}
