{
  "name": "@nestjs-batch/platform",
  "version": "0.0.0",
  "private": false,
  "description": "Platform integrations and support for NestJS Batch",
  "keywords": [
    "batch",
    "nestjs",
    "platform"
  ],
  "homepage": "https://nestjs-port.github.io/nestjs-batch",
  "bugs": {
    "url": "https://github.com/nestjs-port/nestjs-batch/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-batch",
    "directory": "packages/platform"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "prepack": "shx cp ../../README.md README.md"
  },
  "devDependencies": {
    "@nestjs-port/core": "^0.1.1",
    "@nestjs/common": "^11.1.11",
    "@nestjs/core": "^11.1.11",
    "@nestjs/testing": "^11.1.11"
  },
  "peerDependencies": {
    "@nestjs-port/core": "^0.1.1",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0"
  }
}
