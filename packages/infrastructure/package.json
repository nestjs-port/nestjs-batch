{
  "name": "@nestjs-batch/infrastructure",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@testcontainers/redis": "^11.8.1",
    "@nestjs-port/core": "^0.0.1",
    "@nestjs-port/jsdbc": "^0.0.1",
    "@nestjs-batch/commons": "workspace:*",
    "redis": "^5.11.0",
    "ioredis": "^5.10.1",
    "testcontainers": "^11.8.1"
  },
  "peerDependencies": {
    "@nestjs-batch/commons": "*",
    "@nestjs-port/core": "^0.0.1",
    "@nestjs-port/jsdbc": "^0.0.1",
    "redis": "^5.0.0",
    "ioredis": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "redis": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  }
}
