{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 80,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": true,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "ignorePatterns": [".claude", "docs/antora/ui-bundle"],
  "overrides": [
    {
      "files": ["**/*.yml", "**/*.yaml"],
      "options": {
        "singleQuote": true
      }
    }
  ]
}
