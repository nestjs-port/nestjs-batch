{
	"name": "nestjs-batch",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "NestJS Batch Monorepo",
	"scripts": {
		"build": "pnpm -r build",
		"typecheck": "pnpm -r typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "vitest",
		"clean": "pnpm -r clean",
		"prepare": "husky"
	},
	"keywords": [
		"nestjs",
		"batch",
		"monorepo"
	],
	"author": "",
	"license": "MIT",
	"packageManager": "pnpm@9.15.1",
	"engines": {
		"node": ">=18.0.0",
		"pnpm": ">=9.0.0"
	},
	"lint-staged": {
		"*": "biome check --no-errors-on-unmatched"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.10",
		"@types/node": "^25.0.9",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"typescript": "^5.9.3",
		"vitest": "^4.0.16"
	}
}
