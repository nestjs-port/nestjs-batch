{
  "name": "nestjs-batch",
  "version": "0.0.0",
  "private": true,
  "description": "NestJS Batch Monorepo",
  "keywords": [
    "batch",
    "monorepo",
    "nestjs"
  ],
  "homepage": "https://nestjs-port.github.io/nestjs-batch",
  "license": "Apache-2.0",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-batch"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "turbo run test",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=main",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm build && changeset publish",
    "clean": "turbo run clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.0.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "rimraf": "^6.1.3",
    "shx": "^0.4.0",
    "turbo": "^2.8.9",
    "typescript": "^6.0.2",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "*": "oxfmt --write --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx,mjs}": "oxlint --fix"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.1.0"
  },
  "packageManager": "pnpm@11.1.0"
}
